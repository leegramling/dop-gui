PROJECT_NAME           = "dop-gui"
PROJECT_BRIEF          = "Doxygen scaffolding for the dop-gui application architecture"
OUTPUT_DIRECTORY       = docs/doxygen
INPUT                  = src docs
FILE_PATTERNS          = *.h *.cpp *.dox *.md
RECURSIVE              = YES
EXCLUDE                = build external
EXCLUDE_PATTERNS       = */build/* */external/* */.git/*
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS     = NO
REFERENCED_BY_RELATION  = YES
REFERENCES_RELATION    = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
CLASS_GRAPH            = NO
COLLABORATION_GRAPH    = NO
GROUP_GRAPHS           = NO
HAVE_DOT               = NO
GENERATE_TAGFILE       = docs/doxygen/dop-gui.tag
