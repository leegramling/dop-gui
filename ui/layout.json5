{
  menus: [
    {
      label: "File",
      items: [
        { label: "Exit", command: "app.exit" },
      ],
    },
    {
      label: "Scene",
      items: [
        { label: "cubes", command: "scene.load.cubes" },
        { label: "Shapes", command: "scene.load.shapes" },
      ],
    },
  ],
  panels: [
    {
      label: "Scene Info",
      open: true,
      closable: false,
      flags: ["NoCollapse"],
      layout: { x: 24, y: 48, w: 360, h: 520 },
      widgets: [
        { id: "panel-fps", type: "text", label: "FPS", bind: "view.fps.text" },
        { id: "panel-object-count", type: "text", label: "Objects", bind: "scene.objectCount.text" },
        { id: "panel-display-grid", type: "checkbox", label: "Display Grid", bind: "ui.displayGrid", onChange: "ui.grid.set_visible", layout: { x: 16, y: 64, w: 160, h: 24 } },
        { id: "panel-bgcolor", type: "input", label: "Background Color", bind: "view.backgroundColorHex", onChange: "view.background.set_hex", layout: { x: 16, y: 96, w: 220, h: 24 } },
        { id: "panel-scene-select", type: "combo", label: "Scene", bind: "scene.name", onChange: "scene.load", options: ["bootstrap", "cubes", "shapes"], layout: { x: 16, y: 128, w: 220, h: 24 } },
        { id: "panel-theme-dark", type: "radio", label: "Dark", bind: "ui.themeMode", arg: "dark", onClick: "ui.theme.set" },
        { id: "panel-theme-light", type: "radio", label: "Light", bind: "ui.themeMode", arg: "light", onClick: "ui.theme.set" },
        { id: "panel-scene-summary-open", type: "button", label: "Scene Summary", layout: { x: 16, y: 184, w: 144, h: 24 } },
        { id: "popup-scene-summary", type: "popup", label: "Scene Summary" },
        { id: "panel-scene-table", type: "table", label: "Scene Objects", bind: "scene.objects", columns: ["Select", "Id", "Kind", "Position"], layout: { x: 16, y: 232, w: 328, h: 180 } },
      ],
    },
    {
      label: "Properties",
      open: true,
      closable: true,
      flags: ["NoCollapse"],
      layout: { x: 408, y: 48, w: 360, h: 560 },
      flexLayout: {
        type: "column",
        gap: 8,
        children: [
          {
            type: "row",
            gap: 8,
            children: [
              { slot: "panel-properties-selected-object-label", width: 116, height: 24 },
              { slot: "panel-selected-object", flex: 1, height: 24 },
            ],
          },
          { slot: "panel-properties-selected-object", width: 360, height: 20 },
          {
            type: "row",
            gap: 8,
            children: [
              { slot: "input-properties-position-x-label", width: 116, height: 24 },
              { slot: "input-properties-position-x", flex: 1, height: 24 },
            ],
          },
          {
            type: "row",
            gap: 8,
            children: [
              { slot: "input-properties-position-y-label", width: 116, height: 24 },
              { slot: "input-properties-position-y", flex: 1, height: 24 },
            ],
          },
          {
            type: "row",
            gap: 8,
            children: [
              { slot: "input-properties-position-z-label", width: 116, height: 24 },
              { slot: "input-properties-position-z", flex: 1, height: 24 },
            ],
          },
          {
            type: "row",
            gap: 8,
            children: [
              { slot: "input-properties-rotation-x-label", width: 116, height: 24 },
              { slot: "input-properties-rotation-x", flex: 1, height: 24 },
            ],
          },
          {
            type: "row",
            gap: 8,
            children: [
              { slot: "input-properties-rotation-y-label", width: 116, height: 24 },
              { slot: "input-properties-rotation-y", flex: 1, height: 24 },
            ],
          },
          {
            type: "row",
            gap: 8,
            children: [
              { slot: "input-properties-rotation-z-label", width: 116, height: 24 },
              { slot: "input-properties-rotation-z", flex: 1, height: 24 },
            ],
          },
          {
            type: "row",
            gap: 8,
            children: [
              { slot: "input-properties-scale-x-label", width: 116, height: 24 },
              { slot: "input-properties-scale-x", flex: 1, height: 24 },
            ],
          },
          {
            type: "row",
            gap: 8,
            children: [
              { slot: "input-properties-scale-y-label", width: 116, height: 24 },
              { slot: "input-properties-scale-y", flex: 1, height: 24 },
            ],
          },
          {
            type: "row",
            gap: 8,
            children: [
              { slot: "input-properties-scale-z-label", width: 116, height: 24 },
              { slot: "input-properties-scale-z", flex: 1, height: 24 },
            ],
          },
        ],
      },
      widgets: [
        { id: "panel-selected-object", type: "combo", label: "Selected Object", bind: "scene.selectedObjectId", onChange: "scene.select_object", layout: { x: 132, y: 40, w: 200, h: 24 } },
        { id: "input-properties-position-x", type: "input_double", label: "Location X", bind: "scene.selected.position.x", unit: "m", precision: 2 },
        { id: "input-properties-position-y", type: "input_double", label: "Location Y", bind: "scene.selected.position.y", unit: "m", precision: 2 },
        { id: "input-properties-position-z", type: "input_double", label: "Location Z", bind: "scene.selected.position.z", unit: "m", precision: 2 },
        { id: "input-properties-rotation-x", type: "input_double", label: "Rotation X", bind: "scene.selected.rotation.x", unit: "deg", precision: 2 },
        { id: "input-properties-rotation-y", type: "input_double", label: "Rotation Y", bind: "scene.selected.rotation.y", unit: "deg", precision: 2 },
        { id: "input-properties-rotation-z", type: "input_double", label: "Rotation Z", bind: "scene.selected.rotation.z", unit: "deg", precision: 2 },
        { id: "input-properties-scale-x", type: "input_double", label: "Scale X", bind: "scene.selected.scale.x", precision: 6 },
        { id: "input-properties-scale-y", type: "input_double", label: "Scale Y", bind: "scene.selected.scale.y", precision: 6 },
        { id: "input-properties-scale-z", type: "input_double", label: "Scale Z", bind: "scene.selected.scale.z", precision: 6 },
      ],
    },
  ],
}
